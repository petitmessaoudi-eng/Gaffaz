{
  "name": "comparateurtn",
  "version": "1.0.0",
  "description": "Comparateur de prix pour les e-commerces tunisiens — Tunisianet, SpaceNet, Skymil, Mytek",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "scrape": "node scrapers/scraper.js",
    "scrape:tunisianet": "node scrapers/scraper.js --store=Tunisianet",
    "scrape:spacenet": "node scrapers/scraper.js --store=SpaceNet",
    "scrape:skymil": "node scrapers/scraper.js --store=Skymil",
    "scrape:mytek": "node scrapers/scraper.js --store=Mytek",
    "hash-password": "node scripts/hash-password.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mongoose": "^8.4.3",
    "puppeteer": "^22.12.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "ComparateurTN",
  "license": "MIT"
}
